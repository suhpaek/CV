"""###Task 6"""

kernel_blur = np.ones((5,5), np.float32) / 25.0

gray_orig = cv2.cvtColor(img_resized, cv2.COLOR_RGB2GRAY).astype(np.float32)

k = kernel_blur.shape[0]
pad = k // 2
padded = np.pad(gray_orig, ((pad,pad),(pad,pad)), mode="constant", constant_values=0)

out = np.zeros_like(gray_orig, dtype=np.float32)

H, W = gray_orig.shape
for i in range(H):
    for j in range(W):
        region = padded[i:i+k, j:j+k]
        out[i, j] = np.sum(region * kernel_blur)

manual_blur = np.clip(out, 0, 255).astype(np.uint8)

cv_blur_rgb = cv2.filter2D(img_resized, -1, kernel_blur)
cv_blur_gray = cv2.cvtColor(cv_blur_rgb, cv2.COLOR_RGB2GRAY)

plt.figure(figsize=(10,4))
plt.subplot(1,2,1)
plt.imshow(manual_blur, cmap="gray")
plt.title("Manual convolution (gray)")
plt.axis("off")

plt.subplot(1,2,2)
plt.imshow(cv_blur_gray, cmap="gray")
plt.title("cv2.filter2D blur (gray)")
plt.axis("off")
plt.show()

patch_manual = manual_blur[100:105, 100:105]
patch_cv = cv_blur_gray[100:105, 100:105]

print("5x5 patch (manual blur) rows 100-104, cols 100-104:\n", patch_manual)
print("\n5x5 patch (cv2 blur) rows 100-104, cols 100-104:\n", patch_cv)

