"""###Task 1"""

import cv2
import matplotlib.pyplot as plt
import numpy as np

def show_img(title, image):
  plt.imshow(image)
  plt.title(title)
  plt.axis("off")

img=cv2.imread("Twenty-Six Totally Pointless Pics Of Cats Standing Up On Two Feet.jpg")
img=cv2.cvtColor(img, cv2.COLOR_RGB2BGR)

img_resized=cv2.resize(img, (256,256), interpolation = cv2.INTER_AREA)


h,w = img_resized.shape[:2]
center=(w/2,h/2)

M_trans=np.float32([[1,0,45],[0,1,10]])
img_translated = cv2.warpAffine(img_resized, M_trans, (w,h))

M_rot=cv2.getRotationMatrix2D(center, -25, 1)
img_rot= cv2.warpAffine(img_translated, M_rot, (w,h))

plt.figure(figsize=(8,4))
plt.subplot(1,4,1)
show_img("Original: ", img)

plt.subplot(1,4,2)
show_img("Transformed: ", img_rot)

"""###Task 2"""

x, y=80,150
img_rgb1=cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
img_rgb2=cv2.cvtColor(img_rot, cv2.COLOR_BGR2RGB)

rgb_orig=img_rgb1[y, x]
rgb_trans=img_rgb2[y,x]

print("Original: ", rgb_orig)
print("Transformed: ", rgb_trans)

"""Pixels may be different after transformation cause we are rotating and moving the image, it means pixels are moving and rotating with picture too.

