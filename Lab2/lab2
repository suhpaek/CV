"""###Task 8"""

kernel_blur = np.ones((5,5), np.float32) / 25.0
blur_rgb = cv2.filter2D(img_resized, -1, kernel_blur)
gray_blur = cv2.cvtColor(blur_rgb, cv2.COLOR_RGB2GRAY)

H, W = gray_blur.shape
outH, outW = H // 2, W // 2

pooled = np.zeros((outH, outW), dtype=gray_blur.dtype)

for i in range(outH):
    for j in range(outW):
        block = gray_blur[i*2:i*2+2, j*2:j*2+2]
        pooled[i, j] = np.max(block)

print("Input shape:", gray_blur.shape)
print("Output shape:", pooled.shape)

block4x4 = gray_blur[100:104, 100:104]
block2x2 = pooled[50:52, 50:52]

print("\n4x4 block from input (rows 100-103, cols 100-103):\n", block4x4)
print("\n2x2 block from output (rows 50-51, cols 50-51):\n", block2x2)

plt.figure(figsize=(10,4))
plt.subplot(1,2,1)
plt.imshow(gray_blur, cmap="gray")
plt.title("Input (blurred grayscale)")
plt.axis("off")

plt.subplot(1,2,2)
plt.imshow(pooled, cmap="gray")
plt.title("Maxpooled (2x2, stride 2)")
plt.axis("off")
plt.show()

